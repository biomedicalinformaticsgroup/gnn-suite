// Test config for binary classification
params {
    resultsDir = "${baseDir}/results/"
    networkFile = "${baseDir}/testdata/network.tsv"
    geneFile = "${baseDir}/testdata/genes.csv"
    epochs = [50]
    models = ["gcn", "gat", "sage"]
    replicates = 3
    verbose_interval = 10
    dropout = 0.2
    alpha = 0.1
    theta = 0.5
    task_type = "binary"
    dataSet = "test_binary"
    with_mlflow = true
    mlflow_tracking_uri = "http://localhost:5001"
    mlflow_experiment_name = "test_binary_hyperopt"
}
