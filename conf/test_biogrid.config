// Test config for binary classification with biogrid data
params {
    resultsDir = "${baseDir}/results/"
    networkFile = "${baseDir}/data/entrez_biogridhc.tsv"
    geneFile = "${baseDir}/data/entrez_fpancanall_nbiogridhc_lbailey.csv"
    epochs = [50]
    models = ["gcn2", "gcn", "gat", "gat3h", "hgcn", "sage", "gin", "gtn"]
    replicates = 1
    verbose_interval = 10
    dropout = 0.2
    alpha = 0.1
    theta = 0.5
    task_type = "binary"
    dataSet = "test_biogrid"
    with_mlflow = true
    mlflow_tracking_uri = "http://localhost:5002"
    mlflow_experiment_name = "test_biogrid_hyperopt2"
}
